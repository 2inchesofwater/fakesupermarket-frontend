<div class="fs-incentiveboost-item">
  <div class="fs-incentiveboost-item-content">
    <div class="fs-incentiveboost-item-path">
      <span class="fs-incentiveboost-item-group">Gender</span>  <span class="fs-incentiveboost-item-segment">Male</span>
    </div>

    <dl class="fs-incentiveboost-item-remaining">
      <dt>Remaining</dt><dd>107 people</dd>
    </dl>

    <div class="fs-incentiveboost-item-pricing">
      <dl class="fs-incentiveboost-item-amount">
        <dt>Boost incentive by</dt><dd>$2.50</dd>
      </dl>

      <div class="fs-incentiveboost-item-pricing-differential">
        <dl class="fs-incentiveboost-item-was"> 
          <dt>Was</dt><dd>$5.00 / person</dd>
        </dl>

        <dl class="fs-incentiveboost-item-new">
          <dt>New</dt><dd>$7.50 / person</dd>
        </dl>
      </div>
    </div>

    <dl class="fs-incentiveboost-item-additional">
      <dt>Additional incentive</dt><dd>$267.50</dd>
    </dl>
  </div>

  <div class="fs-incentiveboost-item-summary">
    <button type="button" class="fs-btn btn-tertiary btn-icon btn-sm" aria-label="Remove this item">
      <span class="icon">
        {% include "partials/icons/x.njk" %} 
      </span>
    </button>
  </div>
</div>