<div class="fs-inputGroup fs-dashboard-card-sub fs-stepper-pane-radio">
  <fieldset class="fs-fieldset" role="group" aria-describedby="income-hint">
    <div class="fs-label-wrapper">
      <legend class="fs-fieldset__legend">
        <h1 class="fs-fieldset__heading">
          Total household weekly income
        </h1>
      </legend>

      
      <label class="fs-label" for="income">
        How much does your household earn in an average week?
      </label>
      

      
    </div>

    <div class="fs-input-radioGroup" data-module="fs-radios">
      
        
<div class="fs-input-radio size-xl">
